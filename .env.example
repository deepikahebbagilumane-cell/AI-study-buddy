# Gemini API Key for AI features
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Admin Access Password (to protect the Admin Panel)
# Set this to a secret value to prevent unauthorized access
VITE_ADMIN_ACCESS_PASSWORD=YOUR_PASSWORD

# MongoDB Connection String
# Replace <db_password> with your actual database user password
# Example: mongodb+srv://Deepika:your_password@cluster0.i6inonq.mongodb.net/studybuddy?appName=Cluster0
MONGODB_URI=MONGODB_URL

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_here
APP_URL="http://localhost:3000/"